# ─────────────────────────────────────────────────────────────
#  Backend Environment Variables
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Port the Express server listens on
PORT=5005

# MongoDB connection string (must be a Replica Set for Prisma transactions)
DATABASE_URL="mongodb://localhost:27018/cms_db?replicaSet=rs0&directConnection=true"

# Secret key used to sign JWT tokens — change this to any long random string
JWT_SECRET="change_this_to_a_long_random_secret"

# (Optional) Seed admin credentials — used by scripts/seed.js
SEED_EMAIL="admin@bdl.local"
SEED_PASSWORD="admin123"

# (Optional) Allowed CORS origin — defaults to all origins if not set
CORS_ORIGIN="http://localhost:5175"
